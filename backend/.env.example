# Copy to .env and fill in.

# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# v4 read access token (preferred; sent as a Bearer header)
TMDB_ACCESS_TOKEN=

# Async SQLAlchemy URL. Examples:
#   local brew postgres: postgresql+asyncpg://filmclub:filmclub@localhost:5432/filmclub
#   neon/supabase:       postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME
DATABASE_URL=postgresql+asyncpg://filmclub:filmclub@localhost:5432/filmclub

# Comma-free JSON list of allowed frontend origins.
CORS_ORIGINS=["http://localhost:3000"]

# In production (ENVIRONMENT=production) the app refuses to start unless
# SECRET_KEY is a real value (not the default, >=32 chars) and a TMDB credential
# is set. It also hides /docs and sends HSTS.
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Per-IP throttling on auth endpoints (login/signup/password-reset). Default on.
RATE_LIMIT_ENABLED=true

# Public URL of the frontend; used to build links in emails.
FRONTEND_URL=http://localhost:3000

# Email / SMTP. Leave SMTP_HOST blank to log emails to the console instead of
# sending them (the default in development). Set these to deliver real mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=Film Club <no-reply@filmclub.local>
