# Copy to .env and fill in.

# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Async SQLAlchemy URL. Examples:
#   local brew postgres: postgresql+asyncpg://filmclub:filmclub@localhost:5432/filmclub
#   neon/supabase:       postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME
DATABASE_URL=postgresql+asyncpg://filmclub:filmclub@localhost:5432/filmclub

# Comma-free JSON list of allowed frontend origins.
CORS_ORIGINS=["http://localhost:3000"]

ENVIRONMENT=development
